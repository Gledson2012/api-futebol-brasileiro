# Informações do sistema
APP_NAME="API Futebol Brasileiro"

# Tipo de Ambientes: ['local', 'development', 'staging', 'production']
APP_ENV=production

# Hash app key
APP_KEY=

# Debug (Permanecer *false* enquanto *production*)
APP_DEBUG=false

# Adicionar URL do próprio sistema (Default: "http://127.0.0.1:8000")
APP_URL="http://127.0.0.1:8000"

# URL do site referência de dados
URL_SITE_BRASILEIRAO="https://www.terra.com.br/esportes/futebol/brasileiro-serie-a/tabela/"
URL_JOGOS_BRASILEIRAO="https://p1.trrsf.com/api/musa-soccer/ms-standings-games-light?idChampionship=1376&idPhase=&language=pt-BR&country=BR&nav=N&timezone=BR"
URL_DETALHES_JOGOS_BRASILEIRAO="https://www.terra.com.br/esportes/futebol/brasileiro-serie-a/ao-vivo"
URL_JSON_ESTATISTICA_JOGO="https://p1.trrsf.com/api/musa-api/matches-get?lang=pt-BR&type=json&full=true&id="

# URLs dos scrapers da v2 (para ligas internacionais via ESPN)
# URL_BRASILEIRAO="https://www.terra.com.br/esportes/futebol/brasileiro-serie-a/tabela/"
# URL_PREMIER_LEAGUE="https://www.espn.com.br/futebol/tabela/_/liga/ENG.1"
# URL_CHAMPIONS_LEAGUE="https://www.espn.com.br/futebol/tabela/_/liga/UEFA.CHAMPIONS"
# URL_WORLD_CUP="https://www.espn.com.br/futebol/tabela/_/liga/FIFA.WORLD"
# URL_LA_LIGA="https://www.espn.com.br/futebol/tabela/_/liga/ESP.1"
# URL_SERIE_A_ITALY="https://www.espn.com.br/futebol/tabela/_/liga/ITA.1"
# URL_BUNDESLIGA="https://www.espn.com.br/futebol/tabela/_/liga/GER.1"
# URL_CLUB_WORLD_CUP="https://www.espn.com.br/futebol/tabela/_/liga/FIFA.CLUB.WORLD"
# URL_LIBERTADORES="https://www.espn.com.br/futebol/tabela/_/liga/CONMEBOL.LIBERTADORES"

# Níveis de Log
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Conexão Banco de Dados (PRODUÇÃO)
# DB_CONNECTION=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE="api-futebol"
# DB_USERNAME=
# DB_PASSWORD=

# Conexão Banco de Dados (DESENVOLVIMENTO)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE="Futebol-Brasileiro"
DB_USERNAME=postgres
DB_PASSWORD=senha

# Serviço do E-mail (Configurar o de sua preferência)
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"
